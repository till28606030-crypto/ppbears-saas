# Frontend Environment Variables
# Copy this file to .env and fill in your values.

# ─── Supabase ────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_SUPABASE_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...your_anon_key_here

# ─── Backend Dev Proxy ───────────────────────────────────────────────────────
VITE_API_PROXY_TARGET=http://127.0.0.1:3001

# ─── AI Endpoint Auth Token ──────────────────────────────────────────────────
# Must match server AI_ENDPOINT_SECRET
VITE_AI_TOKEN=your-secret-token-here

# ─── Optional: Base path for production (leave blank for root) ────────────────
# VITE_BASE_PATH=/design/
