# Backend Server Environment Variables
# Copy this file to server/.env and fill in your values.
# NEVER commit the actual .env file to git!

# ─── Port ────────────────────────────────────────────────────────────────────
PORT=3001

# ─── Supabase ────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_SUPABASE_PROJECT.supabase.co
# Service role key (FULL database access — keep VERY secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your_service_role_key_here

# ─── Replicate AI ─────────────────────────────────────────────────────────────
# Get from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your_replicate_token_here
# Optional: separate quota for upscale endpoint
REPLICATE_API_TOKEN_UPSCALE=

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Used for: auto-tag, recognize-product, AI chatbot
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_openai_key_here

# ─── Google Gemini (optional fallback) ───────────────────────────────────────
GEMINI_API_KEY=AIza...your_gemini_key_here

# ─── AI Endpoint Security ────────────────────────────────────────────────────
# Frontend must send this in X-AI-Token header for AI endpoints
# Generate a strong random string: openssl rand -hex 32
AI_ENDPOINT_SECRET=your-random-secret-at-least-32-chars-here

# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV=development